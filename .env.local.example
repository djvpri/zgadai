# Database Postgres (Railway)
DATABASE_URL=postgres://user:pass@host:5432/db
DATABASE_SSL=true

# SSO ekosistem Zomet (login lewat Z One)
# Samakan nilainya dengan yang dipakai Z One.
CROSS_APP_SECRET=samakan_dengan_Z_One

# URL hub (untuk tombol kembali / launcher)
NEXT_PUBLIC_ZONE_URL=https://zone.zomet.my.id

# Google Gemini — untuk scan/auto-isi data KTP nasabah
GEMINI_API_KEY=your_gemini_api_key
